<?xml version="1.0" encoding="utf-8"?>
<!-- NeoPOP seek track: flat 4dp bar, accent fill, hard edges -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:id="@android:id/background" android:gravity="center_vertical">
        <shape android:shape="rectangle">
            <size android:height="4dp" />
            <solid android:color="@color/np_border" />
        </shape>
    </item>
    <item android:id="@android:id/progress" android:gravity="center_vertical">
        <clip>
            <shape android:shape="rectangle">
                <size android:height="4dp" />
                <solid android:color="@color/np_accent" />
            </shape>
        </clip>
    </item>
</layer-list>
