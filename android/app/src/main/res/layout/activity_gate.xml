<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/np_bg"
    android:keepScreenOn="true"
    android:padding="16dp">

    <!-- Scroll container to avoid keyboard overlap -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- Monospace countdown timer at top -->
            <TextView
                android:id="@+id/tv_countdown"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:fontFamily="monospace"
                android:text="15:00"
                android:textColor="@color/np_text"
                android:textSize="56sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Subtitle label -->
            <TextView
                android:id="@+id/tv_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="RELEASE GATE ACTIVE"
                android:textColor="@color/np_text_secondary"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.25"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_countdown" />


            <!-- Arithmetic Area -->
            <LinearLayout
                android:id="@+id/layout_challenge"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:gravity="center"
                android:orientation="vertical"
                app:layout_constraintTop_toBottomOf="@id/tv_label">

                <TextView
                    android:id="@+id/tv_progress"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Step 1 / 5"
                    android:textColor="@color/np_accent"
                    android:textSize="12sp"
                    android:letterSpacing="0.2"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_question"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="234 + 567"
                    android:textColor="@color/np_text"
                    android:textSize="36sp"
                    android:textStyle="bold" />

                <!-- Styled answer display (EditText but disabled for manual typing, input is from custom keypad only) -->
                <EditText
                    android:id="@+id/et_answer"
                    android:layout_width="220dp"
                    android:layout_height="60dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/neopop_panel"
                    android:gravity="center"
                    android:hint="?"
                    android:textColorHint="@color/np_text_muted"
                    android:textColor="@color/np_text"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:focusable="false"
                    android:longClickable="false"
                    android:textIsSelectable="false"
                    android:cursorVisible="false"/>
            </LinearLayout>

            <!-- Numeric Keypad Grid -->
            <LinearLayout
                android:id="@+id/layout_keypad"
                android:layout_width="280dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:orientation="vertical"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/layout_challenge">

                <!-- Row 1 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:orientation="horizontal">
                    <Button android:id="@+id/btn_key_1" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="1" android:textSize="20sp" android:textStyle="bold" android:background="@drawable/neopop_key" android:textColor="@color/np_text" android:layout_margin="2dp"/>
                    <Button android:id="@+id/btn_key_2" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="2" android:textSize="20sp" android:textStyle="bold" android:background="@drawable/neopop_key" android:textColor="@color/np_text" android:layout_margin="2dp"/>
                    <Button android:id="@+id/btn_key_3" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="3" android:textSize="20sp" android:textStyle="bold" android:background="@drawable/neopop_key" android:textColor="@color/np_text" android:layout_margin="2dp"/>
                </LinearLayout>

                <!-- Row 2 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:orientation="horizontal"
                    android:layout_marginTop="4dp">
                    <Button android:id="@+id/btn_key_4" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="4" android:textSize="20sp" android:textStyle="bold" android:background="@drawable/neopop_key" android:textColor="@color/np_text" android:layout_margin="2dp"/>
                    <Button android:id="@+id/btn_key_5" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="5" android:textSize="20sp" android:textStyle="bold" android:background="@drawable/neopop_key" android:textColor="@color/np_text" android:layout_margin="2dp"/>
                    <Button android:id="@+id/btn_key_6" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="6" android:textSize="20sp" android:textStyle="bold" android:background="@drawable/neopop_key" android:textColor="@color/np_text" android:layout_margin="2dp"/>
                </LinearLayout>

                <!-- Row 3 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:orientation="horizontal"
                    android:layout_marginTop="4dp">
                    <Button android:id="@+id/btn_key_7" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="7" android:textSize="20sp" android:textStyle="bold" android:background="@drawable/neopop_key" android:textColor="@color/np_text" android:layout_margin="2dp"/>
                    <Button android:id="@+id/btn_key_8" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="8" android:textSize="20sp" android:textStyle="bold" android:background="@drawable/neopop_key" android:textColor="@color/np_text" android:layout_margin="2dp"/>
                    <Button android:id="@+id/btn_key_9" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="9" android:textSize="20sp" android:textStyle="bold" android:background="@drawable/neopop_key" android:textColor="@color/np_text" android:layout_margin="2dp"/>
                </LinearLayout>

                <!-- Row 4 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:orientation="horizontal"
                    android:layout_marginTop="4dp">
                    <ImageButton android:id="@+id/btn_key_backspace" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:src="@drawable/ic_backspace" app:tint="@color/np_text_secondary" android:scaleType="centerInside" android:contentDescription="Backspace" android:background="@drawable/neopop_key" android:layout_margin="2dp"/>
                    <Button android:id="@+id/btn_key_0" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="0" android:textSize="20sp" android:textStyle="bold" android:background="@drawable/neopop_key" android:textColor="@color/np_text" android:layout_margin="2dp"/>
                    <ImageButton android:id="@+id/btn_key_submit" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:src="@drawable/ic_arrow_right" app:tint="@color/np_on_cta" android:scaleType="centerInside" android:contentDescription="Submit answer" android:background="@drawable/neopop_key_submit" android:layout_margin="2dp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Release state (shown after solve/timeout; hidden during active gate) -->
            <LinearLayout
                android:id="@+id/layout_release"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:gravity="center"
                android:orientation="vertical"
                android:visibility="gone"
                app:layout_constraintTop_toBottomOf="@id/tv_label">

                <TextView
                    android:id="@+id/tv_release_outcome"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:textColor="@color/np_text"
                    android:textSize="20sp"
                    android:textStyle="bold" />


                <Button
                    android:id="@+id/btn_release_return"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="32dp"
                    android:background="@drawable/neopop_key_submit"
                    android:paddingHorizontal="32dp"
                    android:text="RETURN"
                    android:textStyle="bold"
                    android:letterSpacing="0.15"
                    android:textColor="@color/np_on_cta" />
            </LinearLayout>

            <!-- Local Music Mini-Player controls -->
            <LinearLayout
                android:id="@+id/layout_media"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="24dp"
                android:background="@drawable/neopop_panel"
                android:orientation="vertical"
                android:padding="16dp"
                app:layout_constraintTop_toBottomOf="@id/layout_keypad"
                app:layout_constraintBottom_toBottomOf="parent">

                <!-- Song Title and Artist -->
                <TextView
                    android:id="@+id/tv_track_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:gravity="center"
                    android:singleLine="true"
                    android:text="No Track Playing"
                    android:textColor="@color/np_text"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <!-- Playback Buttons Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <!-- Shuffle Toggle -->
                    <ImageButton
                        android:id="@+id/btn_media_shuffle"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:src="@drawable/ic_shuffle"
                        app:tint="@color/np_text_secondary"
                        android:scaleType="centerInside"
                        android:contentDescription="Toggle shuffle"
                        android:background="?attr/selectableItemBackgroundBorderless"/>

                    <!-- Seek -15s -->
                    <ImageButton
                        android:id="@+id/btn_media_rewind"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:src="@drawable/ic_rewind"
                        app:tint="@color/np_text"
                        android:scaleType="centerInside"
                        android:contentDescription="Rewind 15 seconds"
                        android:background="?attr/selectableItemBackgroundBorderless"/>

                    <!-- Prev -->
                    <ImageButton
                        android:id="@+id/btn_media_prev"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:src="@drawable/ic_prev"
                        app:tint="@color/np_text"
                        android:scaleType="centerInside"
                        android:contentDescription="Previous track"
                        android:background="?attr/selectableItemBackgroundBorderless"/>

                    <!-- Play / Pause -->
                    <ImageButton
                        android:id="@+id/btn_media_play_pause"
                        android:layout_width="54dp"
                        android:layout_height="54dp"
                        android:background="@drawable/neopop_key_submit"
                        android:src="@drawable/ic_pause"
                        app:tint="@color/np_on_cta"
                        android:scaleType="centerInside"
                        android:contentDescription="Play or pause"
                        android:layout_marginStart="8dp"
                        android:layout_marginEnd="8dp"/>

                    <!-- Next -->
                    <ImageButton
                        android:id="@+id/btn_media_next"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:src="@drawable/ic_next"
                        app:tint="@color/np_text"
                        android:scaleType="centerInside"
                        android:contentDescription="Next track"
                        android:background="?attr/selectableItemBackgroundBorderless"/>

                    <!-- Seek +15s -->
                    <ImageButton
                        android:id="@+id/btn_media_forward"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:src="@drawable/ic_forward"
                        app:tint="@color/np_text"
                        android:scaleType="centerInside"
                        android:contentDescription="Forward 15 seconds"
                        android:background="?attr/selectableItemBackgroundBorderless"/>

                    <!-- Random Distinct Track -->
                    <ImageButton
                        android:id="@+id/btn_media_random"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:src="@drawable/ic_dice"
                        app:tint="@color/np_text_secondary"
                        android:scaleType="centerInside"
                        android:contentDescription="Random track"
                        android:background="?attr/selectableItemBackgroundBorderless"/>

                </LinearLayout>

            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
